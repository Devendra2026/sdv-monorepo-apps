# Convex backend CLI env — copy to `.env.local` (dev) or `.env.production` (self-hosted).
# Never commit real secrets. Root `.gitignore` ignores `.env*` except `!.env.example`.

# --- Local cloud / anonymous agent development (npx convex dev) ---
# CONVEX_DEPLOYMENT=dev:your-deployment # written by `npx convex dev`
# CONVEX_URL=https://your-deployment.convex.cloud

# --- Self-hosted production deploy / export / function-spec ---
# Used by: scripts/deploy-convex-production.mjs, backup-convex.mjs, verify-*.mjs
CONVEX_SELF_HOSTED_URL=https://api.sdvedutech.in
CONVEX_SELF_HOSTED_ADMIN_KEY=replace_with_generate_admin_key_sh_output

# backup-convex.mjs: leave unset/0 for documents-only ZIP (safer on SQLite hosts).
# Set to 1 only off-peak when you need photo/PDF blobs in the backup.
# BACKUP_INCLUDE_STORAGE=0

# On the Convex container / Dokploy env (not this file): use integers only —
# ACTIONS_USER_TIMEOUT_SECS=600
# Empty string causes: Invalid value for ACTIONS_USER_TIMEOUT_SECS ParseIntError

# Optional: Clerk issuer / webhook secrets are set ON the Convex deployment via
#   npx convex env set ... --env-file .env.production
# They are not required in this file for `convex deploy` itself.
