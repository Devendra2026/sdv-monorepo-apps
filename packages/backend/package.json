{
  "name": "@workspace/backend",
  "version": "1.0.0",
  "description": "Backend for the workspace",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "convex dev",
    "deploy": "convex deploy",
    "codegen": "convex codegen",
    "typecheck": "tsc --noEmit -p convex/tsconfig.json",
    "convex:backup": "node ./scripts/backup-convex.mjs"
  },
  "exports": {
    "./convex/*": "./convex/*"
  },
  "dependencies": {
    "convex": "^1.42.1",
    "svix": "^1.82.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "^6.0.3"
  }
}
