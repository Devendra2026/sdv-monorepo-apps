# Example env for infra/convex-self-hosted/docker-compose.yml
# Copy to `.env` beside docker-compose.yml on the Dokploy host (do not commit secrets).
# Variable names match upstream Convex self-hosted compose / run_backend.sh.

# Pin images in production (replace with a concrete tag or digest from ghcr.io).
CONVEX_BACKEND_TAG=latest
CONVEX_DASHBOARD_TAG=latest

PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791

CONVEX_CLOUD_ORIGIN=https://api.sdvedutech.in
CONVEX_SITE_ORIGIN=https://site.sdvedutech.in
NEXT_PUBLIC_DEPLOYMENT_URL=https://api.sdvedutech.in

INSTANCE_NAME=sdv-production
# Required: stable per-instance secret. Generate once and keep offline backup.
# INSTANCE_SECRET=

RUST_LOG=info
REDACT_LOGS_TO_CLIENT=true
DISABLE_BEACON=true
DISABLE_METRICS_ENDPOINT=true

# Document tombstone GC (seconds). Upstream default 172800 (2 days).
# Keep stable; do not bounce this value without reading retention-worker caveats.
DOCUMENT_RETENTION_DELAY=172800

# Concurrency knobs (upstream docker-compose defaults are 16).
APPLICATION_MAX_CONCURRENT_MUTATIONS=16
APPLICATION_MAX_CONCURRENT_QUERIES=16
APPLICATION_MAX_CONCURRENT_V8_ACTIONS=16
APPLICATION_MAX_CONCURRENT_NODE_ACTIONS=16

# Action timeouts (seconds). Do NOT leave blank — empty values log ParseIntError on boot.
ACTIONS_USER_TIMEOUT_SECS=600
V8_ACTION_USER_TIMEOUT_SECS=600
NODE_ACTION_USER_TIMEOUT_SECS=600
HTTP_SERVER_TIMEOUT_SECONDS=300

# Swarm resource hints (Dokploy Advanced → Resources should mirror these).
CONVEX_CPU_LIMIT=2.0
CONVEX_MEMORY_LIMIT=4G
CONVEX_CPU_RESERVATION=1.0
CONVEX_MEMORY_RESERVATION=2G

CONVEX_VOLUME_NAME=sdv-convex-data

# Optional: Postgres/MySQL instead of SQLite (leave blank for SQLite default).
# POSTGRES_URL=
# MYSQL_URL=

# Optional: S3-compatible storage so exports/files leave the Docker volume.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# S3_ENDPOINT_URL=
# AWS_S3_FORCE_PATH_STYLE=true
# S3_STORAGE_EXPORTS_BUCKET=
# S3_STORAGE_FILES_BUCKET=
# S3_STORAGE_MODULES_BUCKET=
# S3_STORAGE_SEARCH_BUCKET=
# S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=
