# Local web development — copy to .env.local (gitignored).
# Use the SAME Clerk app and Convex deployment as the mobile field app.

# Clerk (development instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
NEXT_PUBLIC_CLERK_URL=https://your-instance.clerk.accounts.dev

# Convex dev deployment (from `npx convex dev` in packages/backend)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Optional: must match Convex env CLERK_JWT_ISSUER_DOMAIN when set locally
# CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# Excel export includes photo URLs by default. Set to 0 to skip URL resolution (faster).
# NEXT_PUBLIC_EXPORT_PHOTO_URLS=0
